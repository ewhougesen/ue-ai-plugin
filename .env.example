# z.ai API Configuration
ANTHROPIC_AUTH_TOKEN=your_zai_auth_token_here
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
API_TIMEOUT_MS=180000

# Claude Code Settings
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
CLAUDE_CODE_DISABLE_TELEMETRY=1
CLAUDE_CODE_STRICT_MODEL_ROUTING=1

# Model Routing
ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-4.7
ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-4.5-air
ANTHROPIC_MAX_RETRIES=2
ANTHROPIC_STREAMING=1

# AI Service API Keys
MESHY_API_KEY=your_meshy_api_key_here
CSM_API_KEY=your_csm_api_key_here
KAEDEM_API_KEY=your_kaedim_api_key_here
TRIPOSR_API_KEY=your_triposr_api_key_here

# Server Configuration
GRPC_PORT=50051
HTTP_PORT=8000
LOG_LEVEL=debug
ENVIRONMENT=development
