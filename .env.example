# z.ai API (Required for chat)
ANTHROPIC_AUTH_TOKEN=your_zai_api_key_here
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-4.7

# AI Generation Services (Optional - for 3D model/texture generation)
# Get keys from: https://www.meshy.ai/
MESHY_API_KEY=your_meshy_api_key_here

# Get keys from: https://csm.ai/
CSM_API_KEY=your_csm_api_key_here

# Get keys from: https://platform.stability.ai/
STABILITY_API_KEY=your_stability_api_key_here

# Other services (optional)
KAEDEM_API_KEY=your_kaedem_api_key_here
TRIPOSR_API_KEY=your_triposr_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
